{
  "manifest_version": 3,
  "name": "JSON 格式化助手",
  "version": "1.3.0",
  "description": "选中页面上的 JSON 文本，右键选择 “JSON 格式化”，直接在当前页面以弹窗的方式友好展示。",
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "JSON 格式化助手",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}